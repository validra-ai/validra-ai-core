# =============================================================================
# Validra — environment configuration
# =============================================================================
# This file is optional. Validra works out of the box with no configuration.
# Copy to .env and set only what you need.
#
# Alternatively, pass api_key directly in provider_config on each request
# and skip this file entirely.
# =============================================================================

# -----------------------------------------------------------------------------
# Default provider
# Which provider to use when the request doesn't specify one.
# Options: ollama | openai | anthropic
# -----------------------------------------------------------------------------
# DEFAULT_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Executor
# Timeout in seconds for HTTP requests made to your target API during test runs.
# -----------------------------------------------------------------------------
# EXECUTOR_TIMEOUT=60

# -----------------------------------------------------------------------------
# Ollama
# Only needed if your Ollama instance is not at the default localhost URL.
# Common case: running inside Docker Compose (use the container name as host).
# -----------------------------------------------------------------------------
# OLLAMA_URL=http://ollama:11434/api/generate

# -----------------------------------------------------------------------------
# OpenAI
# Set your API key here to avoid passing it on every request.
# All other OpenAI settings (model, temperature, etc.) have built-in defaults
# and can be overridden per request via provider_config.
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Anthropic
# Set your API key here to avoid passing it on every request.
# All other Anthropic settings (model, temperature, etc.) have built-in defaults
# and can be overridden per request via provider_config.
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=sk-ant-...
